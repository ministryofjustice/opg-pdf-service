{
  "name": "opg-puppeteer-pdf",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "CI=true node --test",
    "test:watch": "node --test --watch",
    "start:webserver": "node -r esm src/server.js",
    "unit-test": "node --test --test-reporter=junit --test-reporter-destination=test-results/junit/results.xml",
    "unit-test-coverage": "NODE_V8_COVERAGE=coverage npm run unit-test -- --experimental-test-coverage",
    "lint:check": "eslint --ignore-pattern .gitignore .",
    "lint:fix": "eslint --fix --ignore-pattern .gitignore .",
    "redoc:build": "redocly build-docs pdf -o openapi/docs/index.html"
  },
  "author": "Ministry of Justice",
  "license": "MIT",
  "dependencies": {
    "body-parser": "2.2.2",
    "cheerio": "^1.0.0-rc.12",
    "esm": "^3.2.25",
    "pino-http": "^11.0.0",
    "polka": "^0.5.2",
    "puppeteer": "22.15.0"
  },
  "devDependencies": {
    "@redocly/cli": "^2.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "pdf2pic": "^3.0.3",
    "pixelmatch": "7.1.0",
    "prettier": "3.8.2",
    "supertest": "7.2.2"
  },
  "resolutions": {
    "braces": "3.0.3"
  }
}
